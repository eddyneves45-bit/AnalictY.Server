# Copie para .env e preencha com valores locais reais.

# Seguranca da API
Jwt__Key=gere-uma-chave-longa-e-aleatoria
Jwt__Issuer=ScadaApi
Jwt__Audience=ScadaClient

# Usuarios iniciais criados apenas no primeiro start do SQLite
SeedUsers__AdminPassword=defina-uma-senha-forte
# SeedUsers__OperatorPassword=
# SeedUsers__ViewerPassword=

# Conexao MySQL inicial opcional para o bootstrap do SQLite
BootstrapMySql__Name=MySQL Local MES
BootstrapMySql__Host=localhost
BootstrapMySql__Port=3306
BootstrapMySql__User=mes_user
BootstrapMySql__Password=defina-uma-senha-forte
BootstrapMySql__Database=banco_mes_mundial

# Teste manual backend/MySqlSimpleTest
MYSQL_TEST_HOST=localhost
MYSQL_TEST_DATABASE=banco_mes_mundial
MYSQL_TEST_USER=mes_user
MYSQL_TEST_PASSWORD=defina-uma-senha-forte
