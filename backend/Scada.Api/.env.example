# JWT Configuration
Jwt__Key=your-super-secret-jwt-key-at-least-32-characters-long
Jwt__Issuer=AnalictY.Server
Jwt__Audience=AnalictY.Web
Jwt__ExpirationMinutes=15

# Database Configuration
ConnectionStrings__DefaultConnection=Data Source=../data/scada.db

# CORS Configuration
Cors__AllowedOrigins=http://localhost:3000,http://127.0.0.1:3000

# Data Directory
AnalictY__DataDirectory=../data

# Auth Configuration
Auth__AllowPublicRegistration=true
Auth__CookieSecure=false
