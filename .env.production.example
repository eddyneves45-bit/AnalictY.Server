# Copy this file to .env on the EC2 instance and fill real secrets there.

ASPNETCORE_ENVIRONMENT=Production

Jwt__Key=replace-with-a-long-random-secret-at-least-48-bytes
Jwt__Issuer=ScadaApi
Jwt__Audience=ScadaClient

# Used only when the local SQLite database is first created.
SeedUsers__AdminPassword=replace-with-a-strong-admin-password

BootstrapMySql__Name=RDS iioT AnalictY
BootstrapMySql__Host=banco-aws.cvcuu2i8konl.sa-east-1.rds.amazonaws.com
BootstrapMySql__Port=3306
BootstrapMySql__User=mes_user
BootstrapMySql__Password=replace-with-rds-mes-user-password
BootstrapMySql__Database=banco_mes_mundial

# Public origin of the web app. Use https://your-domain after TLS is enabled.
Cors__AllowedOrigins__0=https://iiot.analicty.com.br

# Telegram alert notifications. Keep real values only in .env/secrets, never in Git.
Telegram__BotToken=replace-with-telegram-bot-token
Telegram__ChatId=replace-with-telegram-chat-id
Telegram__CooldownMinutes=15
